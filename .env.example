DATABASE_URL="postgresql://flowly:flowlypass@localhost:5432/flowly?schema=public"
JWT_SECRET="your-super-secret-jwt-key-change-in-production"

# AI configuration by feature
AI_PROVIDER_REPORTS="openai"
AI_MODEL_REPORTS="gpt-5.3-mini"

AI_PROVIDER_WORKOUTS="google"
AI_MODEL_WORKOUTS="gemini-2.5-flash"

# Optional fallback provider/model (used when primary fails with rate-limit/provider errors)
AI_PROVIDER_FALLBACK="openai"
AI_MODEL_FALLBACK="gpt-5.3-mini"

# Provider keys (global)
GEMINI_API_KEY=""
OPENAI_API_KEY=""

# Optional provider keys per slot (override global keys)
# GEMINI_API_KEY_REPORTS=""
# GEMINI_API_KEY_WORKOUTS=""
# GEMINI_API_KEY_FALLBACK=""
# OPENAI_API_KEY_REPORTS=""
# OPENAI_API_KEY_WORKOUTS=""
# OPENAI_API_KEY_FALLBACK=""
