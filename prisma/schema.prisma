generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                   String        @id @default(uuid())
  name                 String
  email                String        @unique
  password             String
  plan                 UserPlan      @default(FREE)
  subscriptionStatus   UserSubscriptionStatus @default(INACTIVE)
  subscriptionId       String?
  transactions         Transaction[]
  monthlyReports       MonthlyReport[]
  customCategories     Category[]
  notifications        Notification[]
  createdAt            DateTime      @default(now())
  updatedAt            DateTime      @updatedAt

  @@map("users")
}

model Transaction {
  id               String   @id @default(uuid())
  title            String
  amount            Decimal  @db.Decimal(12, 2)
  installmentAmount Decimal? @db.Decimal(12, 2)
  type             TransactionType
  category         String
  date             DateTime
  userId           String
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  isInstallment    Boolean  @default(false)
  totalInstallments Int?
  purchaseDate     DateTime?
  dueDay           Int?     // day of month (1–31)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@map("transactions")
}

model MonthlyReport {
  id              String   @id @default(uuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  year            Int
  month           Int      // 1-12
  income          Decimal  @db.Decimal(12, 2) @default(0)
  expense         Decimal  @db.Decimal(12, 2) @default(0)
  transactionCount Int     @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([userId, year, month])
  @@index([userId, year, month])
  @@map("monthly_reports")
}

model Category {
  id        String   @id @default(uuid())
  name      String
  icon      String
  color     String
  userId    String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@map("categories")
}

model Notification {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  message   String
  date      DateTime
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([userId, read])
  @@map("notifications")
}

enum UserPlan {
  FREE
  PRO
}

enum UserSubscriptionStatus {
  ACTIVE
  INACTIVE
  CANCELED
}

enum TransactionType {
  INCOME
  EXPENSE
}
