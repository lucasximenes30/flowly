generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                    String                 @id @default(uuid())
  name                  String
  email                 String                 @unique
  password              String
  plan                  UserPlan               @default(FREE)
  subscriptionStatus    UserSubscriptionStatus @default(INACTIVE)
  subscriptionId        String?
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt
  cards                 Card[]
  customCategories      Category[]
  exercises             Exercise[]
  habits                Habit[]
  monthlyReports        MonthlyReport[]
  notifications         Notification[]
  transactions          Transaction[]
  stats                 UserStats?
  workoutDayAssignments WorkoutDayAssignment[]
  workoutLogs           WorkoutLog[]
  workoutPlans          WorkoutPlan[]
  workoutSessions       WorkoutSession[]

  @@map("users")
}

model UserStats {
  id              String    @id @default(uuid())
  userId          String    @unique
  currentStreak   Int       @default(0)
  longestStreak   Int       @default(0)
  score           Int       @default(0)
  lastWorkoutDate DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([score])
  @@map("user_stats")
}

model Transaction {
  id                String          @id @default(uuid())
  title             String
  amount            Decimal         @db.Decimal(12, 2)
  installmentAmount Decimal?        @db.Decimal(12, 2)
  type              TransactionType
  category          String
  date              DateTime
  userId            String
  isInstallment     Boolean         @default(false)
  totalInstallments Int?
  purchaseDate      DateTime?
  dueDay            Int?
  isRecurring       Boolean         @default(false)
  recurringDay      Int?
  isActive          Boolean         @default(true)
  endDate           DateTime?
  cardId            String?
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
  paymentMethod     String?
  card              Card?           @relation(fields: [cardId], references: [id])
  user              User            @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("transactions")
}

model Card {
  id             String        @id @default(uuid())
  userId         String
  name           String
  lastFourDigits String
  dueDay         Int
  closingDay     Int
  color          String        @default("blue")
  limitAmount    Decimal       @default(0) @db.Decimal(12, 2)
  createdAt      DateTime      @default(now())
  user           User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions   Transaction[]

  @@index([userId])
  @@map("cards")
}

model MonthlyReport {
  id               String   @id @default(uuid())
  userId           String
  year             Int
  month            Int
  income           Decimal  @default(0) @db.Decimal(12, 2)
  expense          Decimal  @default(0) @db.Decimal(12, 2)
  transactionCount Int      @default(0)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, year, month])
  @@index([userId, year, month])
  @@map("monthly_reports")
}

model Category {
  id        String   @id @default(uuid())
  name      String
  icon      String
  color     String
  userId    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User?    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("categories")
}

model Notification {
  id        String   @id @default(uuid())
  userId    String
  message   String
  date      DateTime
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, read])
  @@map("notifications")
}

model Habit {
  id          String         @id @default(uuid())
  userId      String
  title       String
  description String?
  icon        String         @default("Target")
  color       String         @default("blue")
  order       Int            @default(0)
  isActive    Boolean        @default(true)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  checkins    HabitCheckin[]
  user        User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("habits")
}

model HabitCheckin {
  id        String   @id @default(uuid())
  habitId   String
  date      String
  completed Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  habit     Habit    @relation(fields: [habitId], references: [id], onDelete: Cascade)

  @@unique([habitId, date])
  @@index([habitId])
  @@map("habit_checkins")
}

model WorkoutPlan {
  id             String                 @id @default(uuid())
  userId         String
  name           String
  isActive       Boolean                @default(true)
  createdAt      DateTime               @default(now())
  updatedAt      DateTime               @updatedAt
  dayAssignments WorkoutDayAssignment[]
  days           WorkoutDay[]
  user           User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  sessions       WorkoutSession[]

  @@index([userId, isActive])
  @@map("workout_plans")
}

model WorkoutDay {
  id             String                 @id @default(uuid())
  planId         String
  name           String
  order          Int
  weekDay        Int?
  createdAt      DateTime               @default(now())
  updatedAt      DateTime               @updatedAt
  dayAssignments WorkoutDayAssignment[]
  exercises      WorkoutDayExercise[]
  plan           WorkoutPlan            @relation(fields: [planId], references: [id], onDelete: Cascade)
  workoutLogs    WorkoutLog[]
  sessions       WorkoutSession[]

  @@index([planId, order])
  @@map("workout_days")
}

model Exercise {
  id                  String                   @id @default(uuid())
  namePt              String
  nameEn              String
  muscleGroup         ExerciseMuscleGroup
  equipment           String?
  imageUrl            String?
  isSystem            Boolean                  @default(true)
  userId              String?
  createdAt           DateTime                 @default(now())
  updatedAt           DateTime                 @updatedAt
  externalId          String?
  source              ExerciseSource           @default(SYSTEM)
  user                User?                    @relation(fields: [userId], references: [id], onDelete: Cascade)
  workoutDayExercises WorkoutDayExercise[]
  workoutExerciseLogs WorkoutExerciseLog[]
  sessionExercises    WorkoutSessionExercise[]

  @@unique([source, externalId])
  @@index([source, externalId])
  @@index([isSystem, muscleGroup])
  @@index([userId, createdAt])
  @@map("exercises")
}

model WorkoutDayExercise {
  id           String     @id @default(uuid())
  workoutDayId String
  exerciseId   String
  order        Int
  sets         Int
  reps         String
  targetWeight Decimal?   @db.Decimal(8, 2)
  notes        String?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  exercise     Exercise   @relation(fields: [exerciseId], references: [id], onDelete: Cascade)
  workoutDay   WorkoutDay @relation(fields: [workoutDayId], references: [id], onDelete: Cascade)

  @@index([workoutDayId, order])
  @@index([exerciseId])
  @@map("workout_day_exercises")
}

model WorkoutSession {
  id           String                   @id @default(uuid())
  userId       String
  planId       String
  workoutDayId String
  date         DateTime                 @default(now())
  completed    Boolean                  @default(false)
  dayNotes     String?
  createdAt    DateTime                 @default(now())
  updatedAt    DateTime                 @updatedAt
  exercises    WorkoutSessionExercise[]
  plan         WorkoutPlan              @relation(fields: [planId], references: [id], onDelete: Cascade)
  user         User                     @relation(fields: [userId], references: [id], onDelete: Cascade)
  workoutDay   WorkoutDay               @relation(fields: [workoutDayId], references: [id], onDelete: Cascade)

  @@index([userId, date])
  @@index([planId])
  @@index([workoutDayId])
  @@map("workout_sessions")
}

model WorkoutSessionExercise {
  id               String         @id @default(uuid())
  workoutSessionId String
  exerciseId       String
  setsDone         Int?
  repsDone         String?
  weightUsed       Decimal?       @db.Decimal(8, 2)
  completed        Boolean        @default(false)
  notes            String?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  exercise         Exercise       @relation(fields: [exerciseId], references: [id], onDelete: Cascade)
  workoutSession   WorkoutSession @relation(fields: [workoutSessionId], references: [id], onDelete: Cascade)

  @@index([workoutSessionId])
  @@index([exerciseId])
  @@map("workout_session_exercises")
}

model WorkoutDayAssignment {
  id           String      @id @default(uuid())
  userId       String
  planId       String
  workoutDayId String
  date         String
  createdAt    DateTime    @default(now())
  plan         WorkoutPlan @relation(fields: [planId], references: [id], onDelete: Cascade)
  user         User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  workoutDay   WorkoutDay  @relation(fields: [workoutDayId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
  @@index([planId])
  @@index([workoutDayId])
  @@map("workout_day_assignments")
}

model WorkoutLog {
  id           String               @id @default(uuid())
  userId       String
  workoutId    String
  date         DateTime             @default(now())
  completed    Boolean              @default(false)
  notes        String?
  createdAt    DateTime             @default(now())
  updatedAt    DateTime             @updatedAt
  exerciseLogs WorkoutExerciseLog[]
  user         User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  workout      WorkoutDay           @relation(fields: [workoutId], references: [id], onDelete: Cascade)

  @@unique([userId, workoutId, date])
  @@index([userId, date])
  @@index([workoutId])
  @@map("workout_logs")
}

model WorkoutExerciseLog {
  id           String     @id @default(uuid())
  workoutLogId String
  exerciseId   String
  done         Boolean    @default(false)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  exercise     Exercise   @relation(fields: [exerciseId], references: [id], onDelete: Cascade)
  workoutLog   WorkoutLog @relation(fields: [workoutLogId], references: [id], onDelete: Cascade)

  @@unique([workoutLogId, exerciseId])
  @@index([exerciseId])
  @@map("workout_exercise_logs")
}

enum UserPlan {
  FREE
  PRO
}

enum UserSubscriptionStatus {
  ACTIVE
  INACTIVE
  CANCELED
}

enum TransactionType {
  INCOME
  EXPENSE
}

enum ExerciseMuscleGroup {
  CHEST
  BACK
  LEGS
  SHOULDERS
  BICEPS
  TRICEPS
  ABS
  GLUTES
  CARDIO
  FULL_BODY
  OTHER
}

enum ExerciseSource {
  SYSTEM
  CUSTOM
  WGER
}
