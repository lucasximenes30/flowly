generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                   String        @id @default(uuid())
  name                 String
  email                String        @unique
  password             String
  plan                 UserPlan      @default(FREE)
  subscriptionStatus   UserSubscriptionStatus @default(INACTIVE)
  subscriptionId       String?
  transactions         Transaction[]
  monthlyReports       MonthlyReport[]
  customCategories     Category[]
  notifications        Notification[]
  cards                Card[]
  habits               Habit[]
  workoutPlans         WorkoutPlan[]
  createdAt            DateTime      @default(now())
  updatedAt            DateTime      @updatedAt

  @@map("users")
}

model Transaction {
  id                String   @id @default(uuid())
  title             String
  amount            Decimal  @db.Decimal(12, 2)
  installmentAmount Decimal? @db.Decimal(12, 2)
  type              TransactionType
  category          String
  date              DateTime
  userId            String
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  isInstallment     Boolean  @default(false)
  totalInstallments Int?
  purchaseDate      DateTime?
  dueDay            Int?     // day of month (1-31) - used for installments
  isRecurring       Boolean  @default(false)
  recurringDay      Int?     // day of month (1-31) - used for recurring
  isActive          Boolean  @default(true)
  endDate           DateTime? // set when recurring is cancelled
  cardId            String?  // optional link to a Card (null when card is deleted)
  card              Card?    @relation(fields: [cardId], references: [id], onDelete: SetNull)
  paymentMethod     String?  // e.g. "credit_card", "debit", "contactless", "pix", "none"
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@map("transactions")
}

model Card {
  id             String        @id @default(uuid())
  userId         String
  user           User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  name           String        // friendly label e.g. "Nubank", "Inter"
  lastFourDigits String        // e.g. "9421"
  dueDay         Int           // dia de vencimento da fatura (1-31)
  closingDay     Int           // dia de fechamento da fatura (1-31)
  color          String        @default("blue")
  limitAmount    Decimal       @db.Decimal(12, 2) @default(0)
  transactions   Transaction[]
  createdAt      DateTime      @default(now())

  @@index([userId])
  @@map("cards")
}

model MonthlyReport {
  id               String   @id @default(uuid())
  userId           String
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  year             Int
  month            Int      // 1-12
  income           Decimal  @db.Decimal(12, 2) @default(0)
  expense          Decimal  @db.Decimal(12, 2) @default(0)
  transactionCount Int      @default(0)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@unique([userId, year, month])
  @@index([userId, year, month])
  @@map("monthly_reports")
}

model Category {
  id        String   @id @default(uuid())
  name      String
  icon      String
  color     String
  userId    String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@map("categories")
}

model Notification {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  message   String
  date      DateTime
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([userId, read])
  @@map("notifications")
}

enum UserPlan {
  FREE
  PRO
}

enum UserSubscriptionStatus {
  ACTIVE
  INACTIVE
  CANCELED
}

enum TransactionType {
  INCOME
  EXPENSE
}

model Habit {
  id          String         @id @default(uuid())
  userId      String
  user        User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  title       String
  description String?
  icon        String         @default("Target")
  color       String         @default("blue")
  order       Int            @default(0)
  isActive    Boolean        @default(true)
  checkins    HabitCheckin[]
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  @@index([userId])
  @@map("habits")
}

model HabitCheckin {
  id        String   @id @default(uuid())
  habitId   String
  habit     Habit    @relation(fields: [habitId], references: [id], onDelete: Cascade)
  date      String   // YYYY-MM-DD
  completed Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([habitId, date])
  @@index([habitId])
  @@map("habit_checkins")
}

model WorkoutPlan {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name      String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, isActive])
  @@map("workout_plans")
}
